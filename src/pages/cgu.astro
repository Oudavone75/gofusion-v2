---
import LegalLayout from '../layouts/LegalLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const content = fs.readFileSync(path.resolve('./src/content/legal/cgu.html'), 'utf-8');
const tocRaw: { id: string; label: string }[] = JSON.parse(
  fs.readFileSync(path.resolve('./src/content/legal/cgu.toc.json'), 'utf-8')
);
const toc = tocRaw.filter((t) => !/^mise-a-jour/i.test(t.id));
---

<LegalLayout
  title="Conditions générales d'utilisation (CGU) | Go Fusion"
  description="Conditions générales d'utilisation de Go Fusion. Définitions, objet, acceptation, accès, propriété intellectuelle, données personnelles et responsabilités."
  canonical="/cgu"
  lastUpdated="30 juillet 2025"
  downloadUrl="/legal/cgu.pdf"
  breadcrumbName="CGU"
  tagLabel="Conditions générales d'utilisation"
  toc={toc}
>
  <Fragment set:html={content} />
</LegalLayout>
