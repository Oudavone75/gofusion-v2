---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogNav from '../../components/BlogNav.astro';
import { SITE } from '../../consts';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const related = allPosts
  .filter((p) => p.id !== post.id)
  .filter((p) => p.data.tags.some((t) => post.data.tags.includes(t)))
  .slice(0, 3);

const fallbackRelated =
  related.length < 3
    ? allPosts.filter((p) => p.id !== post.id && !related.includes(p)).slice(0, 3 - related.length)
    : [];
const relatedPosts = [...related, ...fallbackRelated];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  image: post.data.cover ? `${SITE.url}${post.data.cover}` : `${SITE.url}${SITE.ogImage}`,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: SITE.founder.linkedin,
  },
  publisher: { '@id': `${SITE.url}/#organization` },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE.url}/articles/${post.id}`,
  },
  keywords: post.data.tags.join(', '),
  inLanguage: 'fr-FR',
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE.url}/blog` },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: `${SITE.url}/articles/${post.id}`,
    },
  ],
};

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`/articles/${post.id}`}
  ogImage={post.data.cover ?? SITE.ogImage}
  ogType="article"
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    author: post.data.author,
    tags: post.data.tags,
  }}
  jsonLd={[articleSchema, breadcrumb]}
>
  <BlogNav />
  <main class="blog-page">
    <div class="blog-container-narrow">
      <a href="/blog" class="article-back">← Retour au blog</a>

      <header class="article-header">
        {
          post.data.tags.length > 0 && (
            <div class="article-tags">
              {post.data.tags.map((tag) => (
                <span class="article-tag">{tag}</span>
              ))}
            </div>
          )
        }
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
        <div class="article-meta">
          <span><strong>Par {post.data.author}</strong></span>
          <span>•</span>
          <span>{formatDate(post.data.pubDate)}</span>
          <span>•</span>
          <span>Go Fusion</span>
        </div>
      </header>

      {
        post.data.cover && (
          <img
            src={post.data.cover}
            alt={post.data.title}
            class="article-cover"
            loading="eager"
            decoding="async"
          />
        )
      }

      <article class="article-content">
        <Content />
      </article>

      <aside class="article-cta">
        <h3>Envie de gamifier votre engagement collaborateur ?</h3>
        <p>
          Go Fusion transforme vos priorités stratégiques en parcours gamifiés de 3 minutes par
          jour. Déploiement en 1 semaine.
        </p>
        <a href="mailto:contact@gofusion.fr" class="article-cta-btn">Réserver une démo</a>
      </aside>

      {
        relatedPosts.length > 0 && (
          <section class="related">
            <h2 class="related-title">Ces articles pourraient vous intéresser</h2>
            <div class="related-grid">
              {relatedPosts.map((p) => (
                <a href={`/articles/${p.id}`} class="blog-card">
                  {p.data.cover && (
                    <img
                      src={p.data.cover}
                      alt={p.data.title}
                      class="blog-card-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                  <div class="blog-card-body">
                    <h3 class="blog-card-title">{p.data.title}</h3>
                    <div class="blog-card-footer">
                      <span>{formatDate(p.data.pubDate)}</span>
                      <span class="blog-card-cta">Lire →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>
</BaseLayout>
