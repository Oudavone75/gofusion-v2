---
import BaseLayout from './BaseLayout.astro';
import '../styles/legal.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lastUpdated: string;
  downloadUrl: string;
  toc: { id: string; label: string }[];
  breadcrumbName: string;
  tagLabel: string;
}

const { title, description, canonical, lastUpdated, downloadUrl, toc, breadcrumbName, tagLabel } =
  Astro.props;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.gofusion.fr/' },
    {
      '@type': 'ListItem',
      position: 2,
      name: breadcrumbName,
      item: `https://www.gofusion.fr${canonical}`,
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={breadcrumb}>
  <main class="legal-page">
    <div class="legal-container">
      <a href="/" class="legal-back">← Retour à l’accueil</a>

      <div class="legal-tag">{tagLabel}</div>

      <div class="legal-meta" role="complementary">
        <div class="legal-meta-info">
          <span><strong>Dernière mise à jour :</strong> {lastUpdated}</span>
          <span>Oudavone SAS · 58 rue Monceau · 75008 Paris</span>
        </div>
        <a href={downloadUrl} class="legal-download" download>
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Télécharger en PDF
        </a>
      </div>

      {
        toc.length > 0 && (
          <nav class="legal-toc" aria-label="Sommaire">
            <h2>Sommaire</h2>
            <ol>
              {toc.map((item) => (
                <li>
                  <a href={`#${item.id}`}>{item.label}</a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      <article class="legal-content">
        <slot />
      </article>

      <nav class="legal-footer-nav" aria-label="Autres documents légaux">
        <a href="/mentions-legales">Mentions légales</a>
        <a href="/cgu">CGU</a>
        <a href="/politique-de-confidentialite">Politique de confidentialité</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </main>
</BaseLayout>
